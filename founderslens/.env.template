# FoundersLens — API keys
# Copy this file to .env and fill in. Never commit .env.
# Keys marked REQUIRED must be set for the pipeline to run at all.
# Keys marked OPTIONAL gracefully degrade (agent marks that section "data unavailable").

# ---------- LLM ----------
# REQUIRED — primary LLM for 13 of 14 agents
ANTHROPIC_API_KEY=
# REQUIRED — structured-JSON extraction fallback (Agent 1, 5, 10)
OPENAI_API_KEY=

# ---------- Search & research ----------
# REQUIRED — primary agent search (Tavily free tier: 1000 calls/mo)
TAVILY_API_KEY=
# REQUIRED — semantic niche search (Exa free tier: 1000 calls/mo)
EXA_API_KEY=
# REQUIRED — JS-rendered scraping (Firecrawl free tier: 500 credits/mo)
FIRECRAWL_API_KEY=

# ---------- Trends & signals ----------
# REQUIRED — Reddit via PRAW (create app at https://reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=founderslens:v0.1 (by /u/YOUR_USERNAME)
# OPTIONAL — YouTube Data API (10k quota/day free)
YOUTUBE_API_KEY=
# (no key: Hacker News, Semantic Scholar, pytrends, Wayback, World Bank, OECD, Eurostat, US Census)

# ---------- Business & financial ----------
# OPTIONAL — Crunchbase (30-day trial)
CRUNCHBASE_API_KEY=
# (no key: SEC EDGAR public API)

# ---------- Marketing intelligence ----------
# REQUIRED for Agent 8 — Meta Ad Library (create app at https://developers.facebook.com)
META_ACCESS_TOKEN=
# (no key: Google Ads Transparency, TikTok Creative Center — scraped via Firecrawl)

# ---------- News ----------
# OPTIONAL — NewsAPI free tier: 100 req/day
NEWSAPI_KEY=
# OPTIONAL — GNews free tier
GNEWS_API_KEY=

# ---------- Competitor discovery ----------
# OPTIONAL — ProductHunt API (create app at https://www.producthunt.com/v2/oauth/applications)
PRODUCTHUNT_TOKEN=
# OPTIONAL — BuiltWith free tier
BUILTWITH_API_KEY=

# ---------- Runtime config ----------
# Default language for report output: ru or en
FOUNDERSLENS_LANG=ru
# SQLite path (runs + cache + checkpointer)
FOUNDERSLENS_DB_PATH=./data/runs.db
# Cache TTL in hours (cached tool results reused within this window)
FOUNDERSLENS_CACHE_TTL_HOURS=24
# Offline mode (1 = demo fallback, only use cached data)
FOUNDERSLENS_OFFLINE=0
